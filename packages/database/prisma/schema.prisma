  userAgent String?     @map("user_agent") @db.Text
  createdAt DateTime    @default(now()) @map("created_at")

  // Relations
  actor User? @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([actorId])
  @@index([entity, entityId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

// =============================================================================
// STAFF & PERMISSIONS
// =============================================================================

model StaffAssignment {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String    @map("user_id") @db.Uuid
  hackathonId String    @map("hackathon_id") @db.Uuid
  staffRole   StaffRole @map("staff_role")
  isLead      Boolean   @default(false) @map("is_lead")      // UC0033 AF2: identifies Lead Organizer
  isActive    Boolean   @default(true) @map("is_active")     // UC0033 AF1: soft-revoke support
  revokedAt   DateTime? @map("revoked_at")
  revokedBy   String?   @map("revoked_by") @db.Uuid
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  // Relations
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  hackathon     Hackathon @relation(fields: [hackathonId], references: [id], onDelete: Cascade)
  revokedByUser User?     @relation("StaffAssignmentRevoker", fields: [revokedBy], references: [id], onDelete: SetNull)

  @@unique([userId, hackathonId, staffRole]) // allow multiple roles per event
  @@index([hackathonId])
  @@index([hackathonId, isActive])
  @@map("staff_assignments")
}

// =============================================================================
// STAFF INVITATIONS: event-scoped secure invitations for staff (UC0033)
// =============================================================================

model StaffInvitation {
  id             String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  hackathonId    String           @map("hackathon_id") @db.Uuid
  email          String           @db.VarChar(255)
  staffRole      StaffRole        @map("staff_role")
  token          String           @unique                     // secure one-time invitation token
  status         InvitationStatus @default(PENDING)
  invitedBy      String?          @map("invited_by") @db.Uuid
  expiresAt      DateTime         @map("expires_at")
  acceptedAt     DateTime?        @map("accepted_at")
  acceptedBy     String?          @map("accepted_by") @db.Uuid
  message        String?          @db.Text                    // optional personal note from Lead
  createdAt      DateTime         @default(now()) @map("created_at")

  // Relations
  hackathon      Hackathon @relation(fields: [hackathonId], references: [id], onDelete: Cascade)
  invitedByUser  User?     @relation("StaffInvitationSender", fields: [invitedBy], references: [id], onDelete: SetNull)
  acceptedByUser User?     @relation("StaffInvitationAccepter", fields: [acceptedBy], references: [id], onDelete: SetNull)

  @@index([hackathonId])
  @@index([email])
  @@index([expiresAt])
  @@map("staff_invitations")
}

// =============================================================================
// LOCALIZATION (General-purpose i18n key-value store)
// =============================================================================

model LocalizedString {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  key          String    @db.VarChar(255)
  locale       String    @db.VarChar(5) // "en" or "am"
  value        String    @db.Text
