// =============================================================================
// ORGANIZATION / HUB (institutional multi-tenancy)
// =============================================================================

model Organization {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name               String   @db.VarChar(255)
  nameAm             String?  @map("name_am") @db.VarChar(255)
  slug               String   @unique @db.VarChar(255)
  description        String?  @db.Text
  descriptionAm      String?  @map("description_am") @db.Text
  logoUrl            String?  @map("logo_url")
  websiteUrl         String?  @map("website_url")
  contactEmail       String?  @map("contact_email")
  verificationDocUrl String?  @map("verification_doc_url") // UC0001: institutional proof (e.g., university ID, certificate)
  city               String?
  region             String?  @db.VarChar(100)
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  // Relations
  members    OrganizationMember[]
  hackathons Hackathon[]
  bookmarks  Bookmark[]

  @@index([region])
  @@map("organizations")
}

model OrganizationMember {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  role           OrgMemberRole @default(MEMBER)
  joinedAt       DateTime @default(now()) @map("joined_at")

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([userId])
  @@map("organization_members")
}

// =============================================================================
// COLLABORATIVE DISCUSSIONS (community knowledge sharing & team formation)
// =============================================================================

model Discussion {
  id          String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  hackathonId String           @map("hackathon_id") @db.Uuid
  authorId    String?          @map("author_id") @db.Uuid
  title       String           @db.VarChar(255)
  body        String           @db.Text
  category    String           @default("general") @db.VarChar(50) // e.g., "general", "team_formation", "help", "showcase"
  isPinned    Boolean          @default(false) @map("is_pinned")
  isLocked    Boolean          @default(false) @map("is_locked")
  status      DiscussionStatus @default(PUBLISHED) @map("status")
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")
  // Archival metadata (UC0031)
  isArchived  Boolean          @default(false) @map("is_archived")
  archivedAt  DateTime?        @map("archived_at")
  archivedBy  String?          @map("archived_by") @db.Uuid

  // Relations
  hackathon      Hackathon           @relation(fields: [hackathonId], references: [id], onDelete: Cascade)
  author         User?               @relation(fields: [authorId], references: [id], onDelete: SetNull)
  archivedByUser User?               @relation("DiscussionArchiver", fields: [archivedBy], references: [id], onDelete: SetNull)
  comments       DiscussionComment[]

  @@index([hackathonId, category])
  @@index([hackathonId, isPinned])
  @@index([authorId])
  @@map("discussions")
}

model DiscussionComment {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  discussionId String   @map("discussion_id") @db.Uuid
  authorId     String?  @map("author_id") @db.Uuid
  parentId     String?  @map("parent_id") @db.Uuid
  body         String   @db.Text
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relations
  discussion     Discussion          @relation(fields: [discussionId], references: [id], onDelete: Cascade)
  author         User?               @relation(fields: [authorId], references: [id], onDelete: SetNull)
  parent         DiscussionComment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies        DiscussionComment[] @relation("CommentReplies")
  archivedByUser User?               @relation("DiscussionCommentArchiver", fields: [archivedBy], references: [id], onDelete: SetNull)
  status         DiscussionStatus    @default(PUBLISHED) @map("status")
  // Archival metadata (UC0031)
  isArchived Boolean             @default(false) @map("is_archived")
  archivedAt DateTime?           @map("archived_at")
  archivedBy String?             @map("archived_by") @db.Uuid

  @@index([discussionId])
  @@index([authorId])
  @@index([parentId])
  @@map("discussion_comments")
}

// =============================================================================
// PASSWORD RESET (UC0002 Forgot Password Flow)
// =============================================================================

model PasswordResetToken {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  token     String   @unique
  userId    String   @map("user_id") @db.Uuid
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

// =============================================================================
// SESSIONS (for UC0003 Logout & UC0004 Automatic Session Expiration)
// =============================================================================
model Session {
  id        String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String  @map("user_id") @db.Uuid
  token     String  @unique
  userAgent String? @map("user_agent")
  ipAddress String? @map("ip_address")

  // Required for UC0004: Automatic Expiration
  lastActiveAt DateTime @default(now()) @map("last_active_at")
  expiresAt    DateTime @map("expires_at")

  // Revocation metadata (UC0030)
  revokedAt DateTime? @map("revoked_at")
  revokedBy String?   @map("revoked_by") @db.Uuid

  revokedByUser User? @relation("SessionRevoker", fields: [revokedBy], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

// =============================================================================
// REGISTRATIONS (tracks user registrations for hackathons independent of teams)
// =============================================================================
model Registration {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  hackathonId String   @map("hackathon_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  hackathon Hackathon @relation(fields: [hackathonId], references: [id], onDelete: Cascade)

  @@unique([userId, hackathonId])
  @@index([hackathonId, createdAt])
  @@map("registrations")
}

// =============================================================================
// EVENT FEEDBACK (user-submitted feedback per hackathon)
// =============================================================================
model EventFeedback {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId        String   @map("user_id") @db.Uuid
  hackathonId   String   @map("hackathon_id") @db.Uuid
  orgRating     Int      @map("org_rating")
  rulesRating   Int      @map("rules_rating")
  judgingRating Int      @map("judging_rating")
  comment       String?  @db.Text
  createdAt     DateTime @default(now()) @map("created_at")

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  hackathon Hackathon @relation(fields: [hackathonId], references: [id], onDelete: Cascade)

  @@unique([userId, hackathonId])
  @@map("event_feedbacks")
}

// =============================================================================
// RECOMMENDATIONS (content-based personalized event suggestions)
// =============================================================================
model Recommendation {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String    @map("user_id") @db.Uuid
  hackathonId String    @map("hackathon_id") @db.Uuid
  score       Float     // relevance score from the recommendation engine
  reason      Json?     // explanation metadata (e.g., matched skills, similar past events)
  isViewed    Boolean   @default(false) @map("is_viewed")
  isDismissed Boolean   @default(false) @map("is_dismissed")
  createdAt   DateTime  @default(now()) @map("created_at")
  expiresAt   DateTime? @map("expires_at")

  // Relations
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  hackathon Hackathon @relation(fields: [hackathonId], references: [id], onDelete: Cascade)

  @@unique([userId, hackathonId])
  @@index([userId, isViewed])
  @@index([userId, score])
  @@index([hackathonId])
  @@map("recommendations")
}
