// =============================================================================
// ARCHIVAL: Jobs and records for archiving event metadata and text-only data
// =============================================================================

model ArchiveJob {
  id          String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  hackathonId String?            @map("hackathon_id") @db.Uuid
  createdBy   String?            @map("created_by") @db.Uuid
  status      JobStatus @default(PENDING)
  payload     Json?
  scheduledAt DateTime?
  priority    Int                @default(0)
  attempts    Int                @default(0)
  metadata    Json?
  timeoutAt   DateTime?
  lockedBy    String?            @map("locked_by") @db.Uuid
  lockedAt    DateTime?          @map("locked_at")
  startedAt   DateTime?
  completedAt DateTime?
  error       Json?
  createdAt   DateTime           @default(now()) @map("created_at")

  // Relations
  hackathon     Hackathon? @relation(fields: [hackathonId], references: [id], onDelete: SetNull)
  createdByUser User?      @relation("ArchiveJobCreator", fields: [createdBy], references: [id], onDelete: SetNull)
  records       ArchiveRecord[]

  @@index([hackathonId, status])
  @@index([scheduledAt, status])
  @@index([lockedBy, lockedAt])
  @@map("archive_jobs")
}

model ArchiveRecord {
  id             String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  jobId          String        @map("job_id") @db.Uuid
  entity         String        @db.VarChar(100) // e.g., "discussion", "comment"
  entityId       String        @map("entity_id") @db.Uuid
  storagePath    String?       @map("storage_path")
  mimeType       String?       @map("mime_type")
  fileSize       Int?          @map("file_size")
  checksum       String?
  metadata       Json?         @map("metadata")
  downloadToken  String?       @map("download_token")
  tokenExpiresAt DateTime?     @map("token_expires_at")
  status         ArchiveStatus @default(PENDING)
  attempts       Int           @default(0)
  lastError      Json?
  archivedAt     DateTime?
  archivedBy     String?       @map("archived_by") @db.Uuid
  expiresAt      DateTime?
  createdAt      DateTime      @default(now()) @map("created_at")

  // Relations
  job            ArchiveJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  archivedByUser User?      @relation("ArchiveRecordArchiver", fields: [archivedBy], references: [id], onDelete: SetNull)

  @@index([jobId])
  @@index([entity, entityId])
  @@index([downloadToken])
  @@index([expiresAt])
  @@map("archive_records")
}

// =============================================================================
// SEARCH: unified search documents for current + archived metadata (UC0032)
// =============================================================================

model SearchDocument {
  id         String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  entity     String       @db.VarChar(100) // e.g., "hackathon", "submission", "discussion"
  entityId   String       @map("entity_id") @db.Uuid
  source     SearchSource @default(CURRENT)
  title      String?      @db.VarChar(500) // display title for search results
  url        String?      @db.Text         // deep-link to the original entity
  searchText String       @db.Text         // concatenated searchable text
  metadata   Json?
  indexedAt  DateTime     @default(now()) @map("indexed_at")

  @@index([entity, entityId])
  @@index([source, indexedAt])
  @@map("search_documents")
}

// =============================================================================
// SEARCH LOG: query tracking for analytics, AF1 (no results), and AF2 (latency)
// =============================================================================

model SearchLog {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  query        String   @db.Text
  actorId      String?  @map("actor_id") @db.Uuid   // null for public/anonymous users
  resultCount  Int      @default(0) @map("result_count")
  source       SearchSource?                         // CURRENT, ARCHIVE, or null = both
  durationMs   Int?     @map("duration_ms")          // AF2: detect slow archive retrievals
  ipAddress    String?  @map("ip_address") @db.VarChar(45)
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([actorId])
  @@index([createdAt])
  @@index([resultCount])  // quickly find zero-result queries (AF1 analytics)
  @@map("search_logs")
}

// =============================================================================
// AUDIT & LOGGING
// =============================================================================

model AuditLog {
  id        String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  actorId   String?     @map("actor_id") @db.Uuid
  action    AuditAction
  entity    String      @db.VarChar(100) // e.g., "hackathon", "score", "user"
