  entityId       String        @map("entity_id") @db.Uuid
  storagePath    String?       @map("storage_path")
  mimeType       String?       @map("mime_type")
  fileSize       Int?          @map("file_size")
  checksum       String?
  metadata       Json?         @map("metadata")
  downloadToken  String?       @map("download_token")
  tokenExpiresAt DateTime?     @map("token_expires_at")
  status         ArchiveStatus @default(PENDING)
  attempts       Int           @default(0)
  lastError      Json?
  archivedAt     DateTime?
  archivedBy     String?       @map("archived_by") @db.Uuid
  expiresAt      DateTime?
  createdAt      DateTime      @default(now()) @map("created_at")
  archivedByUser User?         @relation("ArchiveRecordArchiver", fields: [archivedBy], references: [id])
  job            ArchiveJob    @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId])
  @@index([entity, entityId])
  @@index([downloadToken])
  @@index([expiresAt])
  @@map("archive_records")
}

