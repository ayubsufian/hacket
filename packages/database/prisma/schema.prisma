// =============================================================================
// MENTOR-TEAM ASSIGNMENT & INTERACTION LOGGING (FR-COL-03)
// =============================================================================

model MentorAssignment {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  mentorId   String   @map("mentor_id") @db.Uuid
  teamId     String   @map("team_id") @db.Uuid
  isActive   Boolean  @default(true) @map("is_active")
  assignedAt DateTime @default(now()) @map("assigned_at")

  // Relations
  mentor       User                @relation(fields: [mentorId], references: [id], onDelete: Cascade)
  team         Team                @relation(fields: [teamId], references: [id], onDelete: Cascade)
  interactions MentorInteraction[]

  @@unique([mentorId, teamId])
  @@index([teamId])
  @@map("mentor_assignments")
}

model MentorInteraction {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  mentorAssignmentId String   @map("mentor_assignment_id") @db.Uuid
  notes              String   @db.Text
  durationMinutes    Int?     @map("duration_minutes")
  createdAt          DateTime @default(now()) @map("created_at")

  // Relations
  mentorAssignment MentorAssignment @relation(fields: [mentorAssignmentId], references: [id], onDelete: Cascade)

  @@index([mentorAssignmentId])
  @@map("mentor_interactions")
}

// =============================================================================
// MENTOR REQUESTS (meeting/message flow between participant and mentor)
// =============================================================================
model MentorRequest {
  id          String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  requesterId String              @map("requester_id") @db.Uuid
  mentorId    String              @map("mentor_id") @db.Uuid
  teamId      String?             @map("team_id") @db.Uuid
  message     String?             @db.Text
  preferredAt DateTime?           @map("preferred_at")
  status      MentorRequestStatus @default(PENDING)
  createdAt   DateTime            @default(now()) @map("created_at")

  // Relations
  requester User  @relation("MentorRequestRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  mentor    User  @relation("MentorRequestMentor", fields: [mentorId], references: [id], onDelete: Cascade)
  team      Team? @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@index([mentorId])
  @@index([requesterId])
