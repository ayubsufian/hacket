  jobId          String    @unique @map("job_id") @db.Uuid
  storagePath    String    @map("storage_path")
  mimeType       String?   @map("mime_type")
  fileSize       Int?      @map("file_size")
  checksum       String?
  downloadToken  String?   @map("download_token")
  tokenExpiresAt DateTime? @map("token_expires_at")
  expiresAt      DateTime? @map("expires_at")
  metadata       Json?
  createdAt      DateTime  @default(now()) @map("created_at")

  // Relations
  job ReportJob @relation("ReportJobFile", fields: [jobId], references: [id], onDelete: Cascade)

  @@index([downloadToken])
  @@index([expiresAt])
  @@map("report_files")
}

model ReportJob {
  id                 String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  hackathonId        String?      @map("hackathon_id") @db.Uuid
  createdBy          String?      @map("created_by") @db.Uuid
  createdByUser      User?        @relation("ReportJobCreator", fields: [createdBy], references: [id], onDelete: SetNull)
  status             ReportStatus @default(PENDING)
  format             ReportFormat @map("format")
  parameters         Json?        @map("parameters") // criteria (filters, date range, fields)
  scheduledAt        DateTime?
  priority           Int          @default(0)
  attempts           Int          @default(0)
  timeoutAt          DateTime?
  lockedBy           String?      @map("locked_by") @db.Uuid
  lockedAt           DateTime?    @map("locked_at")
  startedAt          DateTime?
  completedAt        DateTime?
  error              Json?
  cancelledAt        DateTime?    @map("cancelled_at")
  cancellationReason String?      @map("cancellation_reason")
  createdAt          DateTime     @default(now()) @map("created_at")

  // Relations
  hackathon Hackathon?  @relation(fields: [hackathonId], references: [id], onDelete: SetNull)
