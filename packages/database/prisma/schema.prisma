generator client {
  provider      = "prisma-client-js"
  output        = "../../../node_modules/.prisma/client"
  binaryTargets = ["native", "debian-openssl-1.1.x", "linux-musl"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id                       String                      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email                    String                      @unique @db.VarChar(255)
  password                 String
  role                     UserRole                    @default(PARTICIPANT)
  isActive                 Boolean                     @default(true) @map("is_active")
  verificationStatus       VerificationStatus          @default(UNVERIFIED) @map("verification_status")
  createdAt                DateTime                    @default(now()) @map("created_at")
  updatedAt                DateTime                    @updatedAt @map("updated_at")
  suspendedAt              DateTime?                   @map("suspended_at")
  suspensionReason         String?                     @map("suspension_reason")
  adminInvitationsAccepted AdminInvitation[]           @relation("AdminInvitationAccepter")
  adminInvitationsSent     AdminInvitation[]           @relation("AdminInvitationSender")
  analyticsJobs            AnalyticsJob[]              @relation("AnalyticsJobCreator")
  archiveJobsCreated       ArchiveJob[]                @relation("ArchiveJobCreator")
  archiveRecordsArchived   ArchiveRecord[]             @relation("ArchiveRecordArchiver")
  auditLogs                AuditLog[]
  bookmarks                Bookmark[]
  certificateIssuanceJobs  CertificateIssuanceJob[]    @relation("CertificateIssuanceJobCreator")
  certificatesIssued       Certificate[]               @relation("CertificateIssuer")
  certificates             Certificate[]
  commentsArchived         DiscussionComment[]         @relation("DiscussionCommentArchiver")
  discussionComments       DiscussionComment[]
  discussionsArchived      Discussion[]                @relation("DiscussionArchiver")
  discussions              Discussion[]
  analyticsSnapshots       EventAnalyticsSnapshot[]    @relation("AnalyticsSnapshotComputer")
  eventFeedbacks           EventFeedback[]
  organizedHackathons      Hackathon[]
  mentorAssignments        MentorAssignment[]
  mentorRequestsReceived   MentorRequest[]             @relation("MentorRequestMentor")
  mentorRequestsSent       MentorRequest[]             @relation("MentorRequestRequester")
  notificationBroadcasts   NotificationBroadcast[]
  notifications            Notification[]
  organizationMemberships  OrganizationMember[]
  passwordResetTokens      PasswordResetToken[]
  recommendations          Recommendation[]
  registrations            Registration[]
  reportJobs               ReportJob[]                 @relation("ReportJobCreator")
  scores                   Score[]
  revokedSessions          Session[]                   @relation("SessionRevoker")
  sessions                 Session[]
  revokedStaffAssignments  StaffAssignment[]           @relation("StaffAssignmentRevoker")
  staffAssignments         StaffAssignment[]
  staffInvitationsAccepted StaffInvitation[]           @relation("StaffInvitationAccepter")
  staffInvitationsSent     StaffInvitation[]           @relation("StaffInvitationSender")
  submissionHistoryChanges SubmissionHistory[]         @relation("SubmissionHistoryChanger")
  receivedInvites          TeamInvitation[]            @relation("InvitationReceiver")
  sentInvitations          TeamInvitation[]            @relation("InvitationSender")
  teamMemberships          TeamMember[]
  notificationPreference   UserNotificationPreference?
  profile                  UserProfile?

  @@map("users")
}

model UserProfile {
  id                         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId                     String    @unique @map("user_id") @db.Uuid
  firstName                  String    @map("first_name")
  lastName                   String    @map("last_name")
  bio                        String?
  avatarUrl                  String?   @map("avatar_url")
  phone                      String?
  university                 String?
  graduationYear             Int?      @map("graduation_year")
  skills                     String[]  @default([])
  interests                  String[]  @default([])
  githubUrl                  String?   @map("github_url")
  linkedinUrl                String?   @map("linkedin_url")
  preferredLocale            String    @default("en") @map("preferred_locale") @db.VarChar(5)
  city                       String?
  region                     String?
  representativeName         String?   @map("representative_name") @db.VarChar(255)
  dateOfBirth                DateTime? @map("date_of_birth")
  isSeekingTeam              Boolean?  @default(true) @map("is_seeking_team")
  mentorMaxDailyInteractions Int?      @map("mentor_max_daily_interactions")
  createdAt                  DateTime  @default(now()) @map("created_at")
  updatedAt                  DateTime  @updatedAt @map("updated_at")
  user                       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

model Hackathon {
  id                      String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slug                    String                   @unique @db.VarChar(255)
  title                   String                   @db.VarChar(255)
  titleAm                 String?                  @map("title_am") @db.VarChar(255)
  description             String
  descriptionAm           String?                  @map("description_am")
  coverImageUrl           String?                  @map("cover_image_url")
  status                  HackathonStatus          @default(DRAFT)
  organizerId             String                   @map("organizer_id") @db.Uuid
  organizationId          String?                  @map("organization_id") @db.Uuid
  maxTeamSize             Int                      @default(5) @map("max_team_size")
  minTeamSize             Int                      @default(1) @map("min_team_size")
  maxParticipants         Int?                     @map("max_participants")
  registrationStart       DateTime                 @map("registration_start")
  registrationEnd         DateTime                 @map("registration_end")
  eventStart              DateTime                 @map("event_start")
  eventEnd                DateTime                 @map("event_end")
  submissionDeadline      DateTime                 @map("submission_deadline")
  feedbackDeadline        DateTime?                @map("feedback_deadline")
  scoreboardReleaseAt     DateTime?                @map("scoreboard_release_at")
  scoreboardType          ScoreboardType           @default(FINAL_ONLY) @map("scoreboard_type")
  feedbackVisibility      FeedbackVisibility       @default(HIDDEN) @map("feedback_visibility")
  feedbackReleaseAt       DateTime?                @map("feedback_release_at")
  enforceFeedbackLock     Boolean                  @default(true) @map("enforce_feedback_lock")
  isCalculating           Boolean                  @default(false) @map("is_calculating")
  resultsPublishedAt      DateTime?                @map("results_published_at")
  judgingPhase            JudgingPhase             @default(NOT_STARTED) @map("judging_phase")
  judgingStart            DateTime?                @map("judging_start")
  judgingEnd              DateTime?                @map("judging_end")
  rules                   String?
  rulesAm                 String?                  @map("rules_am")
  prizes                  Json?
  scoringRules            Json?                    @map("scoring_rules")
  region                  String?                  @db.VarChar(100)
  venue                   String?
  isVirtual               Boolean                  @default(false) @map("is_virtual")
  websiteUrl              String?                  @map("website_url")
  contactEmail            String?                  @map("contact_email")
  createdAt               DateTime                 @default(now()) @map("created_at")
  updatedAt               DateTime                 @updatedAt @map("updated_at")
  analyticsJobs           AnalyticsJob[]
  archiveJobs             ArchiveJob[]
  certificateIssuanceJobs CertificateIssuanceJob[]
  certificates            Certificate[]
  discussions             Discussion[]
  analyticsSnapshots      EventAnalyticsSnapshot[]
  eventFeedbacks          EventFeedback[]
  tags                    HackathonTag[]
  organization            Organization?            @relation(fields: [organizationId], references: [id])
  organizer               User                     @relation(fields: [organizerId], references: [id])
  judgingCriteria         JudgingCriteria[]
  notificationBroadcasts  NotificationBroadcast[]
  recommendations         Recommendation[]
  registrations           Registration[]
  reportJobs              ReportJob[]
  scoreboardEntries       ScoreboardEntry[]
  staffAssignments        StaffAssignment[]
  staffInvitations        StaffInvitation[]
  submissions             Submission[]
  teams                   Team[]

  @@index([status])
  @@index([region])
  @@index([registrationStart, registrationEnd])
  @@map("hackathons")
}

model HackathonTag {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  hackathonId String    @map("hackathon_id") @db.Uuid
  tag         String    @db.VarChar(100)
  hackathon   Hackathon @relation(fields: [hackathonId], references: [id], onDelete: Cascade)

  @@unique([hackathonId, tag])
  @@index([tag])
  @@map("hackathon_tags")
}

model Team {
  id                String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  hackathonId       String             @map("hackathon_id") @db.Uuid
  name              String             @db.VarChar(255)
  description       String?
  neededSkills      String[]           @default([]) @map("needed_skills")
  isOpen            Boolean            @default(true) @map("is_open")
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")
  mentorAssignments MentorAssignment[]
  mentorRequests    MentorRequest[]
  submission        Submission?
  invitations       TeamInvitation[]
  members           TeamMember[]
  hackathon         Hackathon          @relation(fields: [hackathonId], references: [id], onDelete: Cascade)

  @@unique([hackathonId, name])
  @@map("teams")
}

model TeamMember {
  id       String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  teamId   String         @map("team_id") @db.Uuid
  userId   String         @map("user_id") @db.Uuid
  role     TeamMemberRole @default(MEMBER)
  joinedAt DateTime       @default(now()) @map("joined_at")
  team     Team           @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user     User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@index([userId])
  @@map("team_members")
}

model TeamInvitation {
  id         String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  teamId     String           @map("team_id") @db.Uuid
  senderId   String           @map("sender_id") @db.Uuid
  receiverId String           @map("receiver_id") @db.Uuid
  status     InvitationStatus @default(PENDING)
  message    String?
  expiresAt  DateTime         @map("expires_at")
  createdAt  DateTime         @default(now()) @map("created_at")
  updatedAt  DateTime         @updatedAt @map("updated_at")
  receiver   User             @relation("InvitationReceiver", fields: [receiverId], references: [id], onDelete: Cascade)
  sender     User             @relation("InvitationSender", fields: [senderId], references: [id], onDelete: Cascade)
  team       Team             @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@index([receiverId, status])
  @@index([teamId])
  @@map("team_invitations")
}

model Submission {
  id                  String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  teamId              String              @unique @map("team_id") @db.Uuid
  hackathonId         String              @map("hackathon_id") @db.Uuid
  version             Int                 @default(1)
  title               String              @db.VarChar(255)
  description         String?
  githubUrl           String?             @map("github_url")
  videoUrl            String?             @map("video_url")
  demoUrl             String?             @map("demo_url")
  slidesUrl           String?             @map("slides_url")
  fileUrls            String[]            @default([]) @map("file_urls")
  isFeedbackVisible   Boolean             @default(false) @map("is_feedback_visible")
  status              SubmissionStatus    @default(DRAFT)
  submittedAt         DateTime?           @map("submitted_at")
  structuredFeedback  Json?               @map("structured_feedback")
  createdAt           DateTime            @default(now()) @map("created_at")
  updatedAt           DateTime            @updatedAt @map("updated_at")
  scoreboardEntries   ScoreboardEntry[]
  scores              Score[]
  submissionHistories SubmissionHistory[]
  hackathon           Hackathon           @relation(fields: [hackathonId], references: [id], onDelete: Cascade)
  team                Team                @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@index([hackathonId, status])
  @@index([hackathonId, submittedAt])
  @@map("submissions")
}

model SubmissionHistory {
  id                  String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  submissionId        String     @map("submission_id") @db.Uuid
  previousTitle       String?    @map("previous_title") @db.VarChar(255)
  previousDescription String?    @map("previous_description")
  previousFileUrls    String[]   @default([]) @map("previous_file_urls")
  changedAt           DateTime   @default(now()) @map("changed_at")
  changedBy           String?    @map("changed_by") @db.Uuid
  changedByUser       User?      @relation("SubmissionHistoryChanger", fields: [changedBy], references: [id])
  submission          Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@index([submissionId])
  @@map("submission_histories")
}

model ScoreboardEntry {
  id           String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  hackathonId  String     @map("hackathon_id") @db.Uuid
  submissionId String     @map("submission_id") @db.Uuid
  finalScore   Float?     @map("final_score")
  rank         Int?
  aggregatedAt DateTime   @default(now()) @map("aggregated_at")
  hackathon    Hackathon  @relation(fields: [hackathonId], references: [id], onDelete: Cascade)
  submission   Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@unique([hackathonId, submissionId])
  @@map("scoreboard_entries")
}

model JudgingCriteria {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  hackathonId String    @map("hackathon_id") @db.Uuid
  name        String    @db.VarChar(255)
  nameAm      String?   @map("name_am") @db.VarChar(255)
  description String?
  maxScore    Int       @default(10) @map("max_score")
  weight      Float     @default(1.0)
  sortOrder   Int       @default(0) @map("sort_order")
  createdAt   DateTime  @default(now()) @map("created_at")
  hackathon   Hackathon @relation(fields: [hackathonId], references: [id], onDelete: Cascade)
  scores      Score[]

  @@unique([hackathonId, name])
  @@map("judging_criteria")
}

model Score {
  id              String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  submissionId    String          @map("submission_id") @db.Uuid
  judgeId         String          @map("judge_id") @db.Uuid
  criteriaId      String          @map("criteria_id") @db.Uuid
  value           Float
  comment         String?
  isCommentPublic Boolean         @default(false) @map("is_comment_public")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")
  criteria        JudgingCriteria @relation(fields: [criteriaId], references: [id], onDelete: Cascade)
  judge           User            @relation(fields: [judgeId], references: [id])
  submission      Submission      @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@unique([submissionId, judgeId, criteriaId])
  @@index([submissionId])
  @@index([criteriaId, judgeId, createdAt])
  @@index([judgeId, createdAt])
  @@map("scores")
}

model Notification {
  id          String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String                 @map("user_id") @db.Uuid
  type        NotificationType
  title       String                 @db.VarChar(255)
  message     String
  metadata    Json?
  isRead      Boolean                @default(false) @map("is_read")
  readAt      DateTime?              @map("read_at")
  broadcastId String?                @map("broadcast_id") @db.Uuid
  createdAt   DateTime               @default(now()) @map("created_at")
  deliveries  NotificationDelivery[]
  broadcast   NotificationBroadcast? @relation("BroadcastNotifications", fields: [broadcastId], references: [id])
  user        User                   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([userId, createdAt])
  @@index([broadcastId])
  @@map("notifications")
}

model Certificate {
  id              String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId          String                  @map("user_id") @db.Uuid
  hackathonId     String                  @map("hackathon_id") @db.Uuid
  title           String                  @db.VarChar(255)
  type            CertificateType         @default(CERTIFICATE)
  awardTier       String                  @default("general") @map("award_tier") @db.VarChar(50)
  certificateUrl  String?                 @map("certificate_url")
  metadata        Json?
  issuedAt        DateTime                @default(now()) @map("issued_at")
  storagePath     String?                 @map("storage_path")
  mimeType        String?                 @map("mime_type")
  fileSize        Int?                    @map("file_size")
  checksum        String?
  downloadToken   String?                 @map("download_token")
  tokenExpiresAt  DateTime?               @map("token_expires_at")
  issuanceJobId   String?                 @map("issuance_job_id") @db.Uuid
  issuedBy        String?                 @map("issued_by") @db.Uuid
  status          CertificateStatus       @default(PENDING)
  generationError Json?
  hackathon       Hackathon               @relation(fields: [hackathonId], references: [id], onDelete: Cascade)
  issuanceJob     CertificateIssuanceJob? @relation(fields: [issuanceJobId], references: [id])
  issuedByUser    User?                   @relation("CertificateIssuer", fields: [issuedBy], references: [id])
  user            User                    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, hackathonId, type, awardTier])
  @@index([userId, issuedAt])
  @@index([downloadToken])
  @@index([status])
  @@map("certificates")
}

model CertificateIssuanceJob {
  id            String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  hackathonId   String?       @map("hackathon_id") @db.Uuid
  createdBy     String?       @map("created_by") @db.Uuid
  status        JobStatus     @default(PENDING)
  payload       Json?
  createdAt     DateTime      @default(now()) @map("created_at")
  createdByUser User?         @relation("CertificateIssuanceJobCreator", fields: [createdBy], references: [id])
  hackathon     Hackathon?    @relation(fields: [hackathonId], references: [id])
  certificates  Certificate[]

  @@index([hackathonId])
  @@map("certificate_issuance_jobs")
}

model UserNotificationPreference {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @unique @map("user_id") @db.Uuid
  email     Boolean  @default(true)
  push      Boolean  @default(true)
  sms       Boolean  @default(true)
  inApp     Boolean  @default(true) @map("in_app")
  types     String[] @default([])
  updatedAt DateTime @updatedAt @map("updated_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_notification_preferences")
}

model NotificationDelivery {
  id             String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  notificationId String          @map("notification_id") @db.Uuid
  channel        DeliveryChannel
  status         DeliveryStatus  @default(PENDING)
  attempts       Int             @default(0)
  lastError      Json?
  sentAt         DateTime?
  nextAttemptAt  DateTime?
  deliveredAt    DateTime?
  notification   Notification    @relation(fields: [notificationId], references: [id], onDelete: Cascade)

  @@index([notificationId])
  @@index([status])
  @@index([status, nextAttemptAt])
  @@map("notification_deliveries")
}

model NotificationTemplate {
  id         String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name       String                  @db.VarChar(255)
  channel    DeliveryChannel
  subject    String?
  body       String
  metadata   Json?
  createdAt  DateTime                @default(now()) @map("created_at")
  broadcasts NotificationBroadcast[]

  @@unique([name, channel])
  @@map("notification_templates")
}

model NotificationBroadcast {
  id            String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  hackathonId   String?               @map("hackathon_id") @db.Uuid
  templateId    String?               @map("template_id") @db.Uuid
  triggerRule   String?               @map("trigger_rule")
  createdBy     String?               @map("created_by") @db.Uuid
  scheduledAt   DateTime?             @map("scheduled_at")
  payload       Json?
  createdAt     DateTime              @default(now()) @map("created_at")
  createdByUser User?                 @relation(fields: [createdBy], references: [id])
  hackathon     Hackathon?            @relation(fields: [hackathonId], references: [id])
  template      NotificationTemplate? @relation(fields: [templateId], references: [id])
  notifications Notification[]        @relation("BroadcastNotifications")

  @@index([triggerRule])
  @@map("notification_broadcasts")
}

model EventAnalyticsSnapshot {
  id                 String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  hackathonId        String        @map("hackathon_id") @db.Uuid
  schemaVersion      Int           @default(1) @map("schema_version")
  snapshotType       SnapshotType? @map("snapshot_type")
  metrics            Json
  computedAt         DateTime      @default(now()) @map("computed_at")
  computedDurationMs Int?          @map("computed_duration_ms")
  expiresAt          DateTime?     @map("expires_at")
  computedBy         String?       @map("computed_by") @db.Uuid
  sourceJobId        String?       @map("source_job_id") @db.Uuid
  computedByUser     User?         @relation("AnalyticsSnapshotComputer", fields: [computedBy], references: [id])
  hackathon          Hackathon     @relation(fields: [hackathonId], references: [id], onDelete: Cascade)
  sourceJob          AnalyticsJob? @relation(fields: [sourceJobId], references: [id])

  @@index([hackathonId, computedAt])
  @@index([expiresAt])
  @@map("event_analytics_snapshots")
}

model AnalyticsJob {
  id            String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  hackathonId   String?                  @map("hackathon_id") @db.Uuid
  createdBy     String?                  @map("created_by") @db.Uuid
  status        JobStatus                @default(PENDING)
  payload       Json?
  scheduledAt   DateTime?
  priority      Int                      @default(0)
  attempts      Int                      @default(0)
  timeoutAt     DateTime?
  lockedBy      String?                  @map("locked_by") @db.Uuid
  lockedAt      DateTime?                @map("locked_at")
  startedAt     DateTime?
  completedAt   DateTime?
  error         Json?
  createdAt     DateTime                 @default(now()) @map("created_at")
  createdByUser User?                    @relation("AnalyticsJobCreator", fields: [createdBy], references: [id])
  hackathon     Hackathon?               @relation(fields: [hackathonId], references: [id])
  snapshots     EventAnalyticsSnapshot[]

  @@index([hackathonId, status])
  @@index([scheduledAt, status])
  @@index([lockedBy, lockedAt])
  @@map("analytics_jobs")
}

model ReportFile {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  jobId          String    @unique @map("job_id") @db.Uuid
  storagePath    String    @map("storage_path")
  mimeType       String?   @map("mime_type")
  fileSize       Int?      @map("file_size")
  checksum       String?
  downloadToken  String?   @map("download_token")
  tokenExpiresAt DateTime? @map("token_expires_at")
  expiresAt      DateTime? @map("expires_at")
  metadata       Json?
  createdAt      DateTime  @default(now()) @map("created_at")
  job            ReportJob @relation("ReportJobFile", fields: [jobId], references: [id], onDelete: Cascade)

  @@index([downloadToken])
  @@index([expiresAt])
  @@map("report_files")
}

model ReportJob {
  id                 String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  hackathonId        String?      @map("hackathon_id") @db.Uuid
  createdBy          String?      @map("created_by") @db.Uuid
  status             ReportStatus @default(PENDING)
  format             ReportFormat @map("format")
  parameters         Json?        @map("parameters")
  scheduledAt        DateTime?
  priority           Int          @default(0)
  attempts           Int          @default(0)
  timeoutAt          DateTime?
  lockedBy           String?      @map("locked_by") @db.Uuid
  lockedAt           DateTime?    @map("locked_at")
  startedAt          DateTime?
  completedAt        DateTime?
  error              Json?
  cancelledAt        DateTime?    @map("cancelled_at")
  cancellationReason String?      @map("cancellation_reason")
  createdAt          DateTime     @default(now()) @map("created_at")
  file               ReportFile?  @relation("ReportJobFile")
  createdByUser      User?        @relation("ReportJobCreator", fields: [createdBy], references: [id])
  hackathon          Hackathon?   @relation(fields: [hackathonId], references: [id])

  @@index([hackathonId, status])
  @@index([scheduledAt, status])
  @@index([lockedBy, lockedAt])
  @@map("report_jobs")
}

model AdminInvitation {
  id                 String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email              String           @db.VarChar(255)
  role               UserRole         @default(ORGANIZER)
  token              String           @unique
  invitedBy          String?          @map("invited_by") @db.Uuid
  expiresAt          DateTime         @map("expires_at")
  acceptedAt         DateTime?        @map("accepted_at")
  acceptedBy         String?          @map("accepted_by") @db.Uuid
  status             InvitationStatus @default(PENDING)
  cancelledAt        DateTime?        @map("cancelled_at")
  cancellationReason String?          @map("cancellation_reason")
  createdAt          DateTime         @default(now()) @map("created_at")
  acceptedByUser     User?            @relation("AdminInvitationAccepter", fields: [acceptedBy], references: [id])
  invitedByUser      User?            @relation("AdminInvitationSender", fields: [invitedBy], references: [id])

  @@index([email])
  @@index([invitedBy])
  @@index([expiresAt])
  @@map("admin_invitations")
}

model ArchiveJob {
  id            String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  hackathonId   String?         @map("hackathon_id") @db.Uuid
  createdBy     String?         @map("created_by") @db.Uuid
  status        JobStatus       @default(PENDING)
  payload       Json?
  scheduledAt   DateTime?
  priority      Int             @default(0)
  attempts      Int             @default(0)
  metadata      Json?
  timeoutAt     DateTime?
  lockedBy      String?         @map("locked_by") @db.Uuid
  lockedAt      DateTime?       @map("locked_at")
  startedAt     DateTime?
  completedAt   DateTime?
  error         Json?
  createdAt     DateTime        @default(now()) @map("created_at")
  createdByUser User?           @relation("ArchiveJobCreator", fields: [createdBy], references: [id])
  hackathon     Hackathon?      @relation(fields: [hackathonId], references: [id])
  records       ArchiveRecord[]

  @@index([hackathonId, status])
  @@index([scheduledAt, status])
  @@index([lockedBy, lockedAt])
  @@map("archive_jobs")
}

model ArchiveRecord {
  id             String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  jobId          String        @map("job_id") @db.Uuid
