# -----------------------------------------------------------------------------
# HackET Platform - Environment Configuration Template
# -----------------------------------------------------------------------------

# APPLICATION
NODE_ENV=development
PORT=5000
NEXT_PUBLIC_API_URL=http://localhost:5000/api/v1

# DATABASE (NFR-SEC-04: PostgreSQL)
# Replace with: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:password@localhost:5432/hacket_db?schema=public"

# AUTHENTICATION (UC0002: Secure Login)
JWT_SECRET="your_super_secret_random_string_here"
JWT_EXPIRES_IN=7d

# CACHING & SESSION (Subsystem 4.3.1: Redis)
REDIS_URL="redis://localhost:6379"

# OBJECT STORAGE (FR-SUB-01: Project File Handling via Cloudinary/S3)
CLOUDINARY_CLOUD_NAME="your_cloud_name"
CLOUDINARY_API_KEY="your_api_key"
CLOUDINARY_API_SECRET="your_api_secret"

# NOTIFICATIONS & ALERTS (FR-SYS-06: Real-time Alerts)
# Use Mailtrap for development or SendGrid for production
EMAIL_HOST="smtp.mailtrap.io"
EMAIL_PORT=2525
EMAIL_USER="your_smtp_username"
EMAIL_PASS="your_smtp_password"
EMAIL_FROM="noreply@hacket.et"

# LOCALIZATION (FR-SYS-01: Bilingual Support)
DEFAULT_LOCALE=en
SUPPORTED_LOCALES=en,am

# ADMIN INITIALIZATION (UC0030)
INITIAL_ADMIN_EMAIL="admin@hacket.et"
INITIAL_ADMIN_PASSWORD="secure_password_123"