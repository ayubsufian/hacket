# =============================================================================
# HackET Platform — Environment Configuration Template
# =============================================================================
#
# Copy this file to .env and fill in the values.
#   cp .env.example .env
#
# Legend:
#   [REQUIRED]  — App will not start without this
#   [OPTIONAL]  — Has a sensible default; override only if needed
#   [FUTURE]    — Scaffolded for upcoming features; not yet read by code
# =============================================================================

# ── APPLICATION ──────────────────────────────────────────────────────────────

# [OPTIONAL] Node environment: development | production | test
NODE_ENV=development

# [OPTIONAL] Port the Express server listens on (default: 5000)
PORT=5000

# [OPTIONAL] Frontend origin for CORS (default: http://localhost:3000)
CORS_ORIGIN=http://localhost:3000

# [OPTIONAL] Public API base URL used by the frontend and certificate links
NEXT_PUBLIC_API_URL=http://localhost:5000/api/v1

# ── DATABASE (NFR-SEC-04: PostgreSQL) ────────────────────────────────────────

# [REQUIRED] PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://postgres:CHANGE_ME@localhost:5432/hacket_db?schema=public"

# ── AUTHENTICATION (UC0002: Secure Login) ────────────────────────────────────

# [REQUIRED] Secret key for signing JWT tokens — MUST be unique and random
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="CHANGE_ME_GENERATE_WITH_CRYPTO_RANDOM_BYTES"

# [OPTIONAL] JWT token lifetime (default: 7d)
JWT_EXPIRES_IN=7d

# ── CACHING & SESSION (NFR-PER-01: Redis) ────────────────────────────────────

# [REQUIRED] Redis connection URL for session management and leaderboard caching
REDIS_URL="redis://localhost:6379"

# ── OBJECT STORAGE (FR-SUB-01: File Uploads) ─────────────────────────────────
# [FUTURE] Currently using local disk via Multer. Uncomment when migrating
#          to Cloudinary or S3 for production file storage.

# CLOUDINARY_CLOUD_NAME="your_cloud_name"
# CLOUDINARY_API_KEY="your_api_key"
# CLOUDINARY_API_SECRET="your_api_secret"

# ── NOTIFICATIONS & ALERTS (FR-SYS-06: Real-time Alerts) ─────────────────────
# [FUTURE] Currently using simulated email transport. Uncomment when
#          integrating a real SMTP provider (Mailtrap for dev, SendGrid for prod).

# EMAIL_HOST="smtp.mailtrap.io"
# EMAIL_PORT=2525
# EMAIL_USER="your_smtp_username"
# EMAIL_PASS="your_smtp_password"
# EMAIL_FROM="noreply@hacket.et"

# ── LOCALIZATION (FR-SYS-01: Bilingual Support) ─────────────────────────────
# [FUTURE] Locale configuration for future server-side i18n middleware.
#          Currently handled via schema fields (titleAm, descriptionAm, etc.)

# DEFAULT_LOCALE=en
# SUPPORTED_LOCALES=en,am

# ── ADMIN INITIALIZATION (UC0030) ────────────────────────────────────────────

# [OPTIONAL] Credentials for the initial admin account created by the seed script
INITIAL_ADMIN_EMAIL="admin@hacket.et"
INITIAL_ADMIN_PASSWORD="CHANGE_ME_USE_A_STRONG_PASSWORD"